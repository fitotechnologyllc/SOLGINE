rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Platform Assets (Public Read)
    match /cards/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Uploaded via Admin SDK/Console
    }
    
    match /packs/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // User Assets
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // Profile pics usually public
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default fallback
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
